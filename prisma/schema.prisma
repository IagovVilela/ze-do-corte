generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AppointmentStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum StaffRole {
  OWNER
  ADMIN
  STAFF
}

enum ServiceCategory {
  CORTE
  BARBA
  COMBO
  TRATAMENTO
  OUTRO
}

enum OrganizationPlanStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum ClientSubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  PAST_DUE
}

/// Tier comercial Barbernegon (após trial ou após upgrade pago).
enum OrganizationPlanTier {
  TRIAL_FULL
  STARTER
  PRO
}

enum AppointmentPaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
}

/// Tenant Barbernegon — uma organização = uma marca / dono.
model Organization {
  id             String                 @id @default(cuid())
  name           String
  /// Slug público: barbernegon.com/[slug]
  slug           String                 @unique
  planStatus     OrganizationPlanStatus @default(TRIAL)
  planTier       OrganizationPlanTier   @default(TRIAL_FULL)
  trialEndsAt    DateTime?
  /// Cancelamento SaaS agendado: permanece ACTIVE até esta data, depois vira CANCELLED.
  planCancelAt   DateTime?
  /// Billing SaaS (conta Asaas da plataforma)
  asaasCustomerId     String?
  asaasSubscriptionId String?
  /// Conta Asaas do salão (recebe PIX/clube dos clientes)
  asaasApiKeyEnc      String?           @db.Text
  asaasEnabled        Boolean           @default(false)
  asaasAccountEmail   String?
  /// Branding white-label
  logoUrl        String?
  primaryColor   String?                @db.VarChar(16)
  slogan         String?                @db.VarChar(160)
  sloganSecondary String?               @db.VarChar(200)
  heroMediaUrl   String?
  aboutText      String?                @db.Text
  instagramHref  String?
  whatsappHref   String?
  phoneLabel     String?
  timezone       String                 @default("America/Sao_Paulo")
  /// WhatsApp Cloud API (Meta) — credenciais por tenant
  whatsappPhoneNumberId String?         @unique
  whatsappWabaId        String?
  /// Access token criptografado (AES) — nunca em texto puro nas APIs públicas
  whatsappAccessTokenEnc String?        @db.Text
  whatsappDisplayPhone  String?
  whatsappBotEnabled    Boolean         @default(false)
  whatsappConnectedAt   DateTime?
  /// Checklist de onboarding (JSON booleans).
  onboardingJson Json?
  /// Configuração do site institucional (tema + secções/blocos). Ver `src/lib/site-page.ts`.
  siteJson       Json?
  /// Aparece na busca pública `/explorar` (marketplace Barbernegon).
  marketplaceListed Boolean              @default(true)
  /// Média e contagem de avaliações (cache; atualizado ao criar review).
  ratingAvg      Decimal?               @db.Decimal(3, 2)
  ratingCount    Int                    @default(0)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  units              BarbershopUnit[]
  staffMembers       StaffMember[]
  settings           BarbershopSetting[]
  subscriptionPlans  SubscriptionPlan[]
  clientSubscriptions ClientSubscription[]
  whatsappSessions   WhatsAppSession[]
  whatsappOutboundLogs WhatsAppOutboundLog[]
  paymentEvents      PaymentEvent[]
  reviews            OrganizationReview[]
  supportTickets     SupportTicket[]

  @@index([planStatus])
  @@index([asaasSubscriptionId])
  @@index([marketplaceListed, planStatus])
}

model BarbershopUnit {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  addressLine    String?
  city           String?
  phone          String?
  isActive       Boolean       @default(true)
  isDefault      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  appointments   Appointment[]
  staffMembers   StaffMember[]
  services       Service[]
  unitServices   BarbershopUnitService[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([isDefault, isActive])
}

model StaffMember {
  id                    String        @id @default(cuid())
  organizationId        String
  organization          Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email                 String        @unique
  displayName           String?
  phone                 String?
  profileImageUrl       String?
  profileImagePublicId  String?
  websiteBio            String?       @db.VarChar(400)
  showOnWebsite         Boolean       @default(false)
  role                  StaffRole
  passwordHash          String?
  unitId                String?
  unit                  BarbershopUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  sessions              Session[]
  appointments          Appointment[]
  workWeekJson          Json?
  pushSubscriptions     StaffPushSubscription[]
  supportTicketsCreated SupportTicket[]
  supportMessages       SupportTicketMessage[]

  @@index([organizationId])
  @@index([unitId])
  @@index([showOnWebsite, role])
}

model StaffPushSubscription {
  id            String      @id @default(cuid())
  staffMemberId String
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  endpoint      String      @unique
  p256dh        String
  auth          String
  createdAt     DateTime    @default(now())

  @@index([staffMemberId])
}

model Session {
  id            String      @id @default(cuid())
  tokenHash     String      @unique
  staffMemberId String
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  expiresAt     DateTime
  createdAt     DateTime    @default(now())

  @@index([staffMemberId])
  @@index([expiresAt])
}

model BarbershopSetting {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  key            String
  value          String       @db.Text
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId])
}

model Service {
  id              String           @id @default(cuid())
  name            String
  description     String
  category        ServiceCategory  @default(OUTRO)
  durationMinutes Int
  price           Decimal          @db.Decimal(10, 2)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  unitId          String
  unit            BarbershopUnit   @relation(fields: [unitId], references: [id], onDelete: Restrict)
  appointments    Appointment[]
  unitOverrides   BarbershopUnitService[]
  planItems       SubscriptionPlanService[]

  @@unique([unitId, name])
  @@index([category])
  @@index([unitId])
}

model BarbershopUnitService {
  id              String         @id @default(cuid())
  unitId          String
  unit            BarbershopUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)
  serviceId       String
  service         Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  price           Decimal?       @db.Decimal(10, 2)
  durationMinutes Int?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([unitId, serviceId])
  @@index([unitId])
  @@index([serviceId])
}

model Appointment {
  id                String            @id @default(cuid())
  clientName        String
  clientPhone       String
  clientEmail       String?
  notes             String?
  startsAt          DateTime
  endsAt            DateTime
  status            AppointmentStatus @default(CONFIRMED)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  serviceId         String
  service           Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  unitId            String?
  unit              BarbershopUnit?   @relation(fields: [unitId], references: [id], onDelete: SetNull)
  staffMemberId     String?
  staffMember       StaffMember?      @relation(fields: [staffMemberId], references: [id], onDelete: SetNull)
  paidAt            DateTime?
  paymentMethod     String?           @db.VarChar(32)
  /// Valor cobrado no balcão (opcional; default = preço do serviço).
  amountPaid        Decimal?          @db.Decimal(10, 2)
  paymentStatus     AppointmentPaymentStatus @default(UNPAID)
  asaasPaymentId    String?
  clientManageToken String?           @unique @db.VarChar(36)
  /// Se o atendimento usou crédito do clube de assinaturas.
  usedSubscriptionId String?
  usedSubscription   ClientSubscription? @relation(fields: [usedSubscriptionId], references: [id], onDelete: SetNull)
  /// Origem da reserva: site | whatsapp | admin (texto livre curto).
  bookingSource     String?           @db.VarChar(32)
  /// Lembrete WhatsApp já enviado (evita duplicar no cron).
  whatsappReminderSentAt DateTime?
  review            OrganizationReview?

  @@index([startsAt])
  @@index([status])
  @@index([serviceId])
  @@index([unitId])
  @@index([staffMemberId])
  @@index([paidAt])
  @@index([usedSubscriptionId])
  @@index([clientPhone])
  @@index([whatsappReminderSentAt, startsAt])
  @@index([asaasPaymentId])
  @@index([paymentStatus])
}

/// Avaliação pública de uma barbearia (marketplace), tipicamente pós-atendimento.
model OrganizationReview {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointmentId  String?      @unique
  appointment    Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  rating         Int
  comment        String?      @db.VarChar(500)
  clientName     String?
  clientPhone    String
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([clientPhone, organizationId])
}

/// Plano do clube (por organização).
model SubscriptionPlan {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  price          Decimal      @db.Decimal(10, 2)
  /// Ciclo em dias (ex.: 30).
  cycleDays      Int          @default(30)
  /// Quantidade de usos inclusos por ciclo (null = ilimitado dentro dos serviços do plano).
  visitsIncluded Int?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  services       SubscriptionPlanService[]
  subscriptions  ClientSubscription[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model SubscriptionPlanService {
  id      String           @id @default(cuid())
  planId  String
  plan    SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  serviceId String
  service Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([planId, serviceId])
  @@index([serviceId])
}

/// Assinatura de cliente final ao clube da barbearia.
model ClientSubscription {
  id               String                    @id @default(cuid())
  organizationId   String
  organization     Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planId           String
  plan             SubscriptionPlan          @relation(fields: [planId], references: [id], onDelete: Restrict)
  clientName       String
  clientPhone      String
  clientEmail      String?
  status           ClientSubscriptionStatus  @default(ACTIVE)
  startsAt         DateTime                  @default(now())
  currentPeriodEnd DateTime
  visitsUsed       Int                       @default(0)
  cancelledAt      DateTime?
  cancelReason     String?                   @db.VarChar(240)
  notes            String?
  /// Cobrança recorrente na conta Asaas do salão
  asaasCustomerId      String?
  asaasSubscriptionId  String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  appointments     Appointment[]

  @@index([organizationId])
  @@index([planId])
  @@index([clientPhone])
  @@index([status])
  @@index([asaasSubscriptionId])
}

/// Eventos Asaas processados (idempotência do webhook).
model PaymentEvent {
  id               String        @id @default(cuid())
  /// ID único do evento Asaas (quando existir) ou hash sintético.
  asaasEventId     String        @unique
  event            String        @db.VarChar(80)
  paymentId        String?
  subscriptionId   String?
  externalReference String?      @db.VarChar(160)
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  payloadJson      Json?
  processedAt      DateTime      @default(now())

  @@index([paymentId])
  @@index([subscriptionId])
  @@index([organizationId])
  @@index([processedAt])
}

/// Sessão conversacional do bot WhatsApp (por org + telefone do cliente).
model WhatsAppSession {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Dígitos E.164 sem +: ex. 5511999999999
  waUserPhone    String
  state          String       @default("idle") @db.VarChar(40)
  contextJson    Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, waUserPhone])
  @@index([organizationId])
  @@index([updatedAt])
}

enum WhatsAppOutboundKind {
  CONFIRMATION
  REMINDER
  CANCELLATION
  MANUAL
  BOT_REPLY
}

/// Log de mensagens enviadas via Cloud API (auditoria / debug).
model WhatsAppOutboundLog {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointmentId  String?
  waUserPhone    String
  kind           WhatsAppOutboundKind
  metaMessageId  String?
  status         String               @default("sent") @db.VarChar(32)
  errorMessage   String?              @db.Text
  createdAt      DateTime             @default(now())

  @@index([organizationId, createdAt])
  @@index([appointmentId])
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketCategory {
  WHATSAPP
  PAYMENTS
  CLUB
  SITE
  BILLING
  OTHER
}

enum SupportMessageAuthorKind {
  STAFF
  PLATFORM
}

/// Chamado de suporte do salão para a Barbernegon.
model SupportTicket {
  id               String                @id @default(cuid())
  organizationId   String
  organization     Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByStaffId String
  createdByStaff   StaffMember           @relation(fields: [createdByStaffId], references: [id], onDelete: Restrict)
  subject          String                @db.VarChar(160)
  category         SupportTicketCategory @default(OTHER)
  status           SupportTicketStatus   @default(OPEN)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  resolvedAt       DateTime?
  messages         SupportTicketMessage[]

  @@index([organizationId, status, updatedAt])
  @@index([status, updatedAt])
  @@index([createdByStaffId])
}

model SupportTicketMessage {
  id            String                   @id @default(cuid())
  ticketId      String
  ticket        SupportTicket            @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  body          String                   @db.Text
  authorKind    SupportMessageAuthorKind
  authorStaffId String?
  authorStaff   StaffMember?             @relation(fields: [authorStaffId], references: [id], onDelete: SetNull)
  /// E-mail do operador da plataforma (quando authorKind = PLATFORM).
  authorEmail   String?
  createdAt     DateTime                 @default(now())

  @@index([ticketId, createdAt])
  @@index([authorStaffId])
}
